{
  "//": "Beispiel-Permissions fuer das Web-Dev-Multi-Agent-System. Kopiere zu .claude/settings.local.json und passe absolute Pfade + Stack-Commands an dein Projekt an. Die Datei selbst ist gitignored. Die Bash-Allowlist deckt die Default-Stack-Commands (pnpm/npx) ab — bei anderem Paketmanager (npm/yarn/bun) entsprechend ergaenzen.",
  "permissions": {
    "allow": [
      "Bash(pnpm:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git restore:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(git rm:*)",
      "Bash(git remote get-url:*)",
      "Bash(date +%s)",
      "Bash(date -u:*)",
      "Bash(sleep:*)",
      "Bash(curl -s -o /dev/null:*)",
      "Bash(rm {{PROJECT_ROOT_ABS}}/.claude/agent-session.lock)",
      "Read({{PROJECT_ROOT_ABS}}/**)",
      "Write({{PROJECT_ROOT_ABS}}/.claude/qa-reports/**)",
      "Write({{PROJECT_ROOT_ABS}}/.claude/code-reviews/**)",
      "Write({{PROJECT_ROOT_ABS}}/.claude/design-reviews/**)",
      "Write({{PROJECT_ROOT_ABS}}/.claude/live-qa-queue/**)",
      "Write({{PROJECT_ROOT_ABS}}/.claude/live-qa-reports/**)",
      "Write({{PROJECT_ROOT_ABS}}/.claude/live-qa-cache/**)",
      "Write({{PROJECT_ROOT_ABS}}/.claude/plans/**)",
      "Write({{PROJECT_ROOT_ABS}}/.claude/skipped-features.md)",
      "Write({{PROJECT_ROOT_ABS}}/.claude/agent-session.lock)",
      "Edit({{PROJECT_ROOT_ABS}}/BACKLOG.md)",
      "Edit({{PROJECT_ROOT_ABS}}/ROADMAP.md)",
      "Bash(gh issue create:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue close:*)",
      "Bash(gh issue reopen:*)",
      "Bash(gh issue comment:*)",
      "Bash(gh issue edit:*)",
      "Bash(gh label create:*)",
      "Bash(gh label list:*)",
      "Bash(gh api:*)",
      "Bash(gh repo view:*)",
      "mcp__chrome-devtools__navigate_page",
      "mcp__chrome-devtools__navigate_page_history",
      "mcp__chrome-devtools__new_page",
      "mcp__chrome-devtools__select_page",
      "mcp__chrome-devtools__list_pages",
      "mcp__chrome-devtools__close_page",
      "mcp__chrome-devtools__wait_for",
      "mcp__chrome-devtools__click",
      "mcp__chrome-devtools__fill",
      "mcp__chrome-devtools__fill_form",
      "mcp__chrome-devtools__hover",
      "mcp__chrome-devtools__drag",
      "mcp__chrome-devtools__upload_file",
      "mcp__chrome-devtools__handle_dialog",
      "mcp__chrome-devtools__take_screenshot",
      "mcp__chrome-devtools__take_snapshot",
      "mcp__chrome-devtools__list_console_messages",
      "mcp__chrome-devtools__list_network_requests",
      "mcp__chrome-devtools__get_network_request",
      "mcp__chrome-devtools__evaluate_script",
      "mcp__chrome-devtools__performance_start_trace",
      "mcp__chrome-devtools__performance_stop_trace",
      "mcp__chrome-devtools__performance_analyze_insight",
      "mcp__chrome-devtools__resize_page",
      "mcp__chrome-devtools__emulate_cpu",
      "mcp__chrome-devtools__emulate_network"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(git rebase:*)",
      "Bash(git config:*)"
    ],
    "ask": [],
    "defaultMode": "auto",
    "additionalDirectories": [
      "/private/tmp",
      "{{PROJECT_ROOT_ABS}}/.claude"
    ]
  }
}
